# Input
num = int(input("Enter a number: "))

# Convert to positive in case of negative number
num = abs(num)

# Initialize sum
digit_sum = 0

# Calculate sum of digits
while num > 0:
    digit_sum += num % 10  # Add last digit
    num //= 10              # Remove last digit

# Output
print("Sum of digits:", digit_sum)
